# Supabase browser configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-current-publishable-or-anon-key

# Optional Cloudflare Turnstile browser key
VITE_TURNSTILE_SITE_KEY=

# Supabase server configuration (server functions only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-current-publishable-or-anon-key

# Central EmailSender queue — server-side only; never prefix these with VITE_
EMAIL_SENDER_URL=https://your-email-sender.vercel.app
EMAIL_SENDER_PROJECT_KEY=lm_live_replace-with-a-project-key
EMAIL_SENDER_FROM=notifications@your-school-domain.example

# Optional local development origin and loopback email-adapter port
DEV_APP_ORIGIN=https://localhost:5175
PORT=3002
